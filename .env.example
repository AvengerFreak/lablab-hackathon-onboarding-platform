# Supabase — get these from your Supabase project dashboard
# (Settings > API > Project URL & Project API keys)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Discord invite URL for the hackathon server
VITE_DISCORD_INVITE_URL=https://discord.gg/your-invite-code

# Fireworks AI Configuration
FIREWORKS_API_KEY=your_private_fireworks_api_credential_here
# Discord server ID where team channels will be created
DISCORD_SERVER_ID=your-discord-server-id

# ── Supabase Edge Function secrets (set in Supabase Dashboard → Edge Functions → Secrets) ──
# GITHUB_PAT=ghp_...                         # PAT with repo scope — creates private repos & adds collaborators
# GITHUB_TEMPLATE_OWNER=your-org             # Optional: template repo owner
# GITHUB_TEMPLATE_REPO=hackathon-starter     # Optional: template repo name
# DISCORD_BOT_TOKEN=your-discord-bot-token    # Bot token with Manage Channels + Manage Roles permissions
# DISCORD_GUILD_ID=your-discord-server-id     # Discord server where team channels are created
